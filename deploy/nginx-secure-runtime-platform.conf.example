# Копіюйте цей файл як nginx-secure-runtime-platform.conf і замініть your-domain.com на ваш домен.
# Потім: sudo cp deploy/nginx-secure-runtime-platform.conf /etc/nginx/sites-available/your-domain.com
# Або використовуйте deploy/setup-nginx-certbot.sh — він сам підставить домен з змінної DOMAIN.

server {
    listen 80;
    server_name your-domain.com;
    client_max_body_size 50M;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
